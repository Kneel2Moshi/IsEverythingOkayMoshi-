local function getPlayerRole(p) 	
    local char = p.Character 	
    local bp = p:FindFirstChild("Backpack") 	
    local hasKnife = (char and char:FindFirstChild("Knife")) or (bp and bp:FindFirstChild("Knife")) 	
    local hasGun = (char and (char:FindFirstChild("Gun") or char:FindFirstChild("Revolver"))) or (bp and (bp:FindFirstChild("Gun") or bp:FindFirstChild("Revolver"))) 	
    if hasKnife then return "Murderer", C_RED end 	
    if hasGun then return "Sheriff", C_BLUE end 	
    return "Innocent", C_GREEN 
end 

local function getMurderer() 	
    for _, p in ipairs(Players:GetPlayers()) do 		
        if p ~= localPlayer and playerRoles[p] == "Murderer" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then 			
            return p 		
        end 	
    end 
end 

local function buildTagForPlayer(p) 	
    if p == localPlayer then return end 	
    local char = p.Character 	
    if not char then return end 	
    local head = char:WaitForChild("Head", 4) 	
    if not head then return end 	
    local roleName, roleColor = getPlayerRole(p) 	
    playerRoles[p] = roleName 	
    if activeEsp[p] then pcall(function() activeEsp[p]:Destroy() end) end 	
    
    local bGui = Instance.new("BillboardGui") 	
    bGui.Name = p.Name .. "_TagESP" 	
    bGui.Size = UDim2.new(0, 180, 0, 42) 	
    bGui.StudsOffset = Vector3.new(0, 3.8, 0) 	
    bGui.AlwaysOnTop = true 	
    
    local label = Instance.new("TextLabel") 	
    label.Size = UDim2.new(1, 0, 1, 0) 	
    label.BackgroundTransparency = 1 	
    label.Font = Enum.Font.RobotoMono 	
    label.TextSize = 12 
    label.TextStrokeTransparency = 0 	
    label.TextStrokeColor3 = C_BLACK 	
    label.Text = flaggedExploiters[p] and string.format("%s\n[!! CHEATER: %s]", p.Name:upper(), flaggedExploiters[p]) or string.format("%s\n[%s]", p.Name:upper(), roleName) 	
    label.TextColor3 = flaggedExploiters[p] and C_ORANGE or roleColor 	
    label.Visible = espEnabled 	
    label.Parent = bGui 	
    bGui.Parent = head 	
    activeEsp[p] = bGui 	
    
    if not activeOutlines[p] or activeOutlines[p].Parent ~= OutlineStorage then 		
        if activeOutlines[p] then pcall(function() activeOutlines[p]:Destroy() end) end 		
        local hl = Instance.new("Highlight") 		
        hl.Name = p.Name .. "_Outline" 		
        hl.FillTransparency = 0.87 		
        hl.OutlineTransparency = 0 		
        hl.OutlineColor = flaggedExploiters[p] and C_ORANGE or roleColor 		
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 		
        hl.Enabled = espEnabled 		
        hl.Adornee = char 		
        hl.Parent = OutlineStorage 		
        activeOutlines[p] = hl 	
    else 		
        activeOutlines[p].Adornee = char 		
        activeOutlines[p].OutlineColor = flaggedExploiters[p] and C_ORANGE or roleColor 		
        activeOutlines[p].Enabled = espEnabled 	
    end 
end 

local function applyEspTags(p) 	
    if p == localPlayer then return end 	
    clearHistory(p) 	
    p.CharacterAdded:Connect(function() 		
        clearHistory(p) 		
        task.wait(0.3) 		
        buildTagForPlayer(p) 	
    end) 	
    if p.Character then task.spawn(buildTagForPlayer, p) end 
end 

local function isHeldByPlayer(obj) 	
    for _, p in ipairs(Players:GetPlayers()) do 		
        if p.Character and obj:IsDescendantOf(p.Character) then return true end 	
    end 	
    return false 
end 

local function scanForDroppedGun() 	
    for _, obj in ipairs(Workspace:GetDescendants()) do 		
        if (obj.Name == "GunDrop" or obj.Name == "DroppedGun") and not isHeldByPlayer(obj) then 			
            if obj:IsA("BasePart") then cachedDroppedGun = obj; return 			
            elseif obj:FindFirstChildWhichIsA("BasePart") then 				
                cachedDroppedGun = obj:FindFirstChildWhichIsA("BasePart"); return 			
            end 		
        end 		
        if obj:IsA("Tool") and (obj.Name == "Gun" or obj.Name == "Revolver") and not isHeldByPlayer(obj) then 			
            local h = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart", true) 			
            if h then cachedDroppedGun = h; return end 		
        end 	
    end 	
    cachedDroppedGun = nil 
end 

