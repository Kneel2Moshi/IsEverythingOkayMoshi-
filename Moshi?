local function animateMenuToggle(open) 	
    if uiTweenInProgress then return end 	
    uiTweenInProgress = true 	
    if open then 		
        MainFrame.Size = UDim2.new(0, 245, 0, 0) 		
        MainFrame.Visible = true 		
        local t = TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 245, 0, 225)}) 		
        t:Play(); t.Completed:Wait() 		
        menuOpenState = true 	
    else 		
        local t = TweenService:Create(MainFrame, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 245, 0, 0)}) 		
        t:Play(); t.Completed:Wait() 		
        MainFrame.Visible = false 		
        menuOpenState = false 	
    end 	
    uiTweenInProgress = false 
end 

