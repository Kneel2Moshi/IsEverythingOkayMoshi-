createActionButton("TELEPORT TO ACTIVE MAP", 11.2, function(btn)
	local activeMap = nil
	local containers = {Workspace:FindFirstChild("Normal"), Workspace:FindFirstChild("Map"), Workspace:FindFirstChild("Maps")}
	for _, folder in pairs(containers) do
		if folder then
			for _, child in ipairs(folder:GetChildren()) do
				if child:IsA("Model") and child.Name ~= "RegularLobby" and child.Name ~= "Lobby" then
					activeMap = child
					break
				end
			end
		end
		if activeMap then break end
	end
	
	if not activeMap then
		for _, desc in ipairs(Workspace:GetChildren()) do
			if desc:IsA("Model") and desc:FindFirstChild("Spawns") and desc.Name ~= "RegularLobby" and desc.Name ~= "Lobby" then
				activeMap = desc
				break
			end
		end
	end
	
	if activeMap then
		local spawnLocation = activeMap:FindFirstChild("Spawns", true) or activeMap:FindFirstChild("Spawn", true)
		local targetPart = spawnLocation and spawnLocation:FindFirstChildWhichIsA("BasePart", true) or activeMap:FindFirstChildWhichIsA("BasePart", true)
		
		if targetPart then
			safeTeleport(targetPart.CFrame * CFrame.new(0, 4, 0))
			btn.Text = "TP'D TO: " .. activeMap.Name:upper()
			task.delay(1.5, function() btn.Text = "TELEPORT TO ACTIVE MAP" end)
			return
		end
	end
	btn.Text = "NO ACTIVE MAP FOUND"
	task.delay(1.5, function() btn.Text = "TELEPORT TO ACTIVE MAP" end)
end)

