local function hasMobilityPerk(p) 	
    local char = p.Character 	
    local bp = p:FindFirstChild("Backpack") 	
    if not char then return false end 	
    if char:FindFirstChild("Haste") or (bp and bp:FindFirstChild("Haste")) then return true end 	
    if char:FindFirstChild("SpeedCoil") or (bp and bp:FindFirstChild("SpeedCoil")) then return true end 	
    if playerRoles[p] == "Murderer" then return true end 	
    return false 
end 

