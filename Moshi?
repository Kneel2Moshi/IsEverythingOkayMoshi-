local function getPlayerRole(targetPlayer)
	local character = targetPlayer.Character
	local backpack = targetPlayer:FindFirstChild("Backpack")
	
	local hasKnife = (character and character:FindFirstChild("Knife")) or 
	                 (backpack and backpack:FindFirstChild("Knife"))
	                 
	local hasGun = (character and character:FindFirstChild("Gun")) or 
	               (backpack and backpack:FindFirstChild("Gun")) or
	               (character and character:FindFirstChild("Revolver")) or
	               (backpack and backpack:FindFirstChild("Revolver"))

	if hasKnife then
		return "Murderer", Color3.fromRGB(255, 0, 0)
	elseif hasGun then
		return "Sheriff", Color3.fromRGB(0, 180, 255)
	end
	
	return "Innocent", Color3.fromRGB(0, 255, 0)
end

local function getMurderer()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer then
			local role = playerRoles[p]
			if role == "Murderer" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				return p
			end
		end
	end
	return nil
end

local function buildTagForPlayer(targetPlayer)
	if targetPlayer == localPlayer then return end
	local character = targetPlayer.Character
	if not character then return end
	
	local head = character:WaitForChild("Head", 4)
	if not head then return end
	
	local roleName, roleColor = getPlayerRole(targetPlayer)
	playerRoles[targetPlayer] = roleName
	
	if activeEsp[targetPlayer] then pcall(function() activeEsp[targetPlayer]:Destroy() end) end
	
	local bGui = Instance.new("BillboardGui")
	bGui.Name = targetPlayer.Name .. "_TagESP"
	bGui.Size = UDim2.new(0, 160, 0, 35)
	bGui.StudsOffset = Vector3.new(0, 3.5, 0) 
	bGui.AlwaysOnTop = true
	
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.Code
	label.TextSize = 11
	label.TextStrokeTransparency = 0.2
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.Text = string.format("%s\n[%s]", targetPlayer.Name:upper(), roleName)
	label.TextColor3 = roleColor
	label.Visible = espEnabled
	
	label.Parent = bGui
	bGui.Parent = head
	activeEsp[targetPlayer] = bGui
	
	if not activeOutlines[targetPlayer] or activeOutlines[targetPlayer].Parent ~= OutlineStorage then
		if activeOutlines[targetPlayer] then pcall(function() activeOutlines[targetPlayer]:Destroy() end) end
		
		local highlight = Instance.new("Highlight")
		highlight.Name = targetPlayer.Name .. "_Outline"
		highlight.FillTransparency = 0.85
		highlight.OutlineTransparency = 0
		highlight.OutlineColor = roleColor
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Enabled = espEnabled
		highlight.Adornee = character
		highlight.Parent = OutlineStorage
		activeOutlines[targetPlayer] = highlight
	else
		activeOutlines[targetPlayer].Adornee = character
		activeOutlines[targetPlayer].OutlineColor = roleColor
		activeOutlines[targetPlayer].Enabled = espEnabled
	end
end

local function applyEspTags(targetPlayer)
	if targetPlayer == localPlayer then return end
	
	targetPlayer.CharacterAdded:Connect(function(char)
		task.wait(0.3)
		buildTagForPlayer(targetPlayer)
	end)
	
	if targetPlayer.Character then
		task.spawn(buildTagForPlayer, targetPlayer)
	end
end

local function isHeldByPlayer(object)
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character and object:IsDescendantOf(player.Character) then
			return true
		end
	end
	return false
end

local function scanForDroppedGun()
	for _, object in ipairs(Workspace:GetDescendants()) do
		if (object.Name == "GunDrop" or object.Name == "DroppedGun") and not isHeldByPlayer(object) then
			if object:IsA("BasePart") then
				cachedDroppedGun = object
				return
			elseif object:FindFirstChildWhichIsA("BasePart") then
				cachedDroppedGun = object:FindFirstChildWhichIsA("BasePart")
				return
			end
		end
		
		if object:IsA("Tool") and (object.Name == "Gun" or object.Name == "Revolver") then
			if not isHeldByPlayer(object) then
				local handle = object:FindFirstChild("Handle") or object:FindFirstChildWhichIsA("BasePart", true)
				if handle then
					cachedDroppedGun = handle
					return
				end
			end
		end
	end
	cachedDroppedGun = nil
end

task.spawn(function()
	while true do
		task.wait(0.25)
		scanForDroppedGun()
		
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= localPlayer and p.Character then
				local role, color = getPlayerRole(p)
				playerRoles[p] = role
				
				local gui = activeEsp[p]
				local hasHead = p.Character:FindFirstChild("Head")
				
				if espEnabled and hasHead then
					if not gui or not gui.Parent or gui.Parent ~= hasHead then
						buildTagForPlayer(p)
						gui = activeEsp[p]
					end
					
					local lbl = gui and gui:FindFirstChildOfClass("TextLabel")
					if lbl then
						lbl.Text = string.format("%s\n[%s]", p.Name:upper(), role)
						lbl.TextColor3 = color
						lbl.Visible = true
					end
					
					local outline = activeOutlines[p]
					if outline then
						outline.OutlineColor = color
						outline.Enabled = true
						outline.Adornee = p.Character
					end
				end
			end
		end
	end
end)

local function updateDroppedGunEsp()
	if cachedDroppedGun and gunEspEnabled then
		if not droppedGunEspInstance or droppedGunEspInstance.Parent ~= cachedDroppedGun then
			if droppedGunEspInstance then droppedGunEspInstance:Destroy() end
			
			droppedGunEspInstance = Instance.new("BillboardGui")
			droppedGunEspInstance.Name = "DroppedGunESP"
			droppedGunEspInstance.Size = UDim2.new(0, 140, 0, 25)
			droppedGunEspInstance.StudsOffset = Vector3.new(0, 2, 0)
			droppedGunEspInstance.AlwaysOnTop = true
			
			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, 0, 1, 0)
			label.BackgroundTransparency = 1
			label.Font = Enum.Font.Code
			label.TextSize = 12
			label.TextColor3 = Color3.fromRGB(255, 235, 0) 
			label.TextStrokeTransparency = 0.2
			label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
			label.Text = "★ DROPPED GUN ★"
			
			label.Parent = droppedGunEspInstance
			droppedGunEspInstance.Parent = cachedDroppedGun
		end
	else
		if droppedGunEspInstance then
			droppedGunEspInstance:Destroy()
			droppedGunEspInstance = nil
		end
	end
end

local function findPartialPlayer(searchStr)
	searchStr = searchStr:lower()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer and (p.Name:lower():sub(1, #searchStr) == searchStr or p.DisplayName:lower():sub(1, #searchStr) == searchStr) then
			return p
		end
	end
	return nil
end

local function safeTeleport(targetCFrame)
	local char = localPlayer.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	
	if hrp then
		hrp.AssemblyLinearVelocity = Vector3.zero
		hrp.AssemblyAngularVelocity = Vector3.zero
	end
	
	char:PivotTo(targetCFrame)
	
	if humanoid then
		humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	end
end

-- RenderStepped System Loop Handles Camera tracking updates
RunService.RenderStepped:Connect(function()
	if spectateEnabled and selectedPlayerName ~= "" then
		local targetPlayer = Players:FindFirstChild(selectedPlayerName)
		local targetChar = targetPlayer and targetPlayer.Character
		local targetHumanoid = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
		
		if targetHumanoid then
			camera.CameraSubject = targetHumanoid
			return
		end
	end

	if camLockEnabled then
		local murderer = getMurderer()
		local mudHrp = murderer and murderer.Character and murderer.Character:FindFirstChild("HumanoidRootPart")
		
		if mudHrp then
			-- Calculate advanced lead aim projection position vector using target's live momentum fields
			local timeFactor = (predictionLevel * 0.05)
			local predictedPos = mudHrp.Position + (mudHrp.AssemblyLinearVelocity * timeFactor)
			
			local targetLookCFrame = CFrame.lookAt(camera.CFrame.Position, predictedPos)
			local alphaFactor = math.clamp(1 / (smoothnessLevel * 2), 0.01, 1)
			camera.CFrame = camera.CFrame:Lerp(targetLookCFrame, alphaFactor)
			
			-- Render crosshair indicator overlay path line if structural feature active
			if aimViewerEnabled then
				local screenPos, onScreen = camera:WorldToViewportPoint(predictedPos)
				if onScreen then
					aimLine.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
					aimLine.To = Vector2.new(screenPos.X, screenPos.Y)
					aimLine.Visible = true
				else
					aimLine.Visible = false
				end
			else
				aimLine.Visible = false
			end
		else
			aimLine.Visible = false
		end
	else
		aimLine.Visible = false
	end
end)

RunService.PreSimulation:Connect(function()
	updateDroppedGunEsp()
	
	local character = localPlayer.Character
	if not character then return end
	
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.WalkSpeed ~= customWalkSpeed then
		humanoid.WalkSpeed = customWalkSpeed
	end

	if not antiFlingEnabled then return end
	
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	local currentVelocity = hrp.AssemblyLinearVelocity
	local currentAngular = hrp.AssemblyAngularVelocity
	
	local isJumpingOrFalling = false
	if humanoid then
		local state = humanoid:GetState()
		if state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall then
			isJumpingOrFalling = true
		end
	end

	if isJumpingOrFalling then
		if math.abs(currentVelocity.X) > 35 or math.abs(currentVelocity.Z) > 35 then
			hrp.AssemblyLinearVelocity = Vector3.new(0, currentVelocity.Y, 0)
		end
	else
		if currentVelocity.Magnitude > 35 or math.abs(currentVelocity.Y) > 40 then
			hrp.AssemblyLinearVelocity = Vector3.new(0, math.clamp(currentVelocity.Y, -20, 20), 0)
		end
	end
	
	if currentAngular.Magnitude > 5 then
		hrp.AssemblyAngularVelocity = Vector3.zero
	end
	
	for _, descendant in ipairs(character:GetChildren()) do
		if descendant:IsA("BasePart") and descendant.Name ~= "HumanoidRootPart" then
			descendant.CanCollide = false
		end
	end
end)

