local function safeTeleport(cf) 	
    local char = localPlayer.Character; if not char then return end 	
    local hrp = char:FindFirstChild("HumanoidRootPart") 	
    local hum = char:FindFirstChildOfClass("Humanoid") 	
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero; hrp.AssemblyAngularVelocity = Vector3.zero end 	
    char:PivotTo(cf) 	
    if hum then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end 
end 

RunService.RenderStepped:Connect(function() 	
    if spectateEnabled and selectedPlayerName ~= "" then 		
        local tp = Players:FindFirstChild(selectedPlayerName) 		
        local th = tp and tp.Character and tp.Character:FindFirstChildOfClass("Humanoid") 		
        if th then camera.CameraSubject = th end 	
    end 	
    if targetAimViewerEnabled and selectedPlayerName ~= "" then 		
        local tp = Players:FindFirstChild(selectedPlayerName) 		
        local head = tp and tp.Character and tp.Character:FindFirstChild("Head") 		
        if head then 			
            local ep = head.Position + head.CFrame.LookVector * 120 			
            local s1, on1 = camera:WorldToViewportPoint(head.Position) 			
            local s2, on2 = camera:WorldToViewportPoint(ep) 			
            if on1 and on2 then 				
                targetAimLine.From = Vector2.new(s1.X, s1.Y) 				
                targetAimLine.To = Vector2.new(s2.X, s2.Y) 				
                targetAimLine.Visible = true 			
            else targetAimLine.Visible = false end 		
        else targetAimLine.Visible = false end 	
    else targetAimLine.Visible = false end 	
    if camLockEnabled then 		
        local murd = getMurderer() 		
        local mhrp = murd and murd.Character and murd.Character:FindFirstChild("HumanoidRootPart") 		
        if mhrp then 			
            local pred = mhrp.Position + mhrp.AssemblyLinearVelocity * (predictionLevel * 0.05) 			
            camera.CFrame = camera.CFrame:Lerp( 				
                CFrame.lookAt(camera.CFrame.Position, pred), 				
                math.clamp(1 / (smoothnessLevel * 2), 0.01, 1) 			
            ) 			
            if aimViewerEnabled then 				
                local sp, on = camera:WorldToViewportPoint(pred) 				
                if on then 					
                    aimLine.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2) 					
                    aimLine.To = Vector2.new(sp.X, sp.Y) 					
                    aimLine.Visible = true 				
                else aimLine.Visible = false end 			
            else aimLine.Visible = false end 		
        else aimLine.Visible = false end 	
    else aimLine.Visible = false end 
end) 

RunService.PreSimulation:Connect(function() 	
    updateDroppedGunEsp() 	
    if detectionEnabled then 		
        for _, p in ipairs(Players:GetPlayers()) do 			
            if p ~= localPlayer and p.Character then 				
                local hrp = p.Character:FindFirstChild("HumanoidRootPart") 				
                local hum = p.Character:FindFirstChildOfClass("Humanoid") 				
                if hrp and hum then 					
                    local pos = hrp.Position 					
                    local vel = hrp.AssemblyLinearVelocity 					
                    local rvel = hrp.AssemblyAngularVelocity 					
                    local hist = playerHistory[p] 					
                    if hist then 						
                        local wf = hist.warmupFrames or 0 						
                        local warmedUp = wf >= MIN_WARMUP_FRAMES 						
                        if warmedUp then 							
                            if vel.Magnitude > FLING_VEL_THRESHOLD or rvel.Magnitude > FLING_VEL_THRESHOLD then 								
                                markAsExploiter(p, "FLING") 							
                            end 							
                            if hist.lastCFrame then 								
                                local dot = hrp.CFrame.LookVector:Dot(hist.lastCFrame.LookVector) 								
                                if dot < AIMBOT_DOT_THRESHOLD and rvel.Magnitude > AIMBOT_RVEL_MIN then 									
                                    hist.aimTicks = (hist.aimTicks or 0) + 1 									
                                    if hist.aimTicks >= AIMBOT_TICK_NEEDED then 										
                                        markAsExploiter(p, "AIMBOT") 									
                                    end 								
                                else 									
                                    hist.aimTicks = math.max(0, (hist.aimTicks or 0) - 1) 								
                                end 							
                            end 							
                            if not hasMobilityPerk(p) then 								
                                local hspeed = Vector3.new(vel.X, 0, vel.Z).Magnitude 								
                                if hspeed > SPEED_THRESHOLD then 									
                                    hist.speedTicks = (hist.speedTicks or 0) + 1 									
                                    if hist.speedTicks >= SPEED_TICKS_NEEDED then 										
                                        markAsExploiter(p, "SPEED") 									
                                    end 								
                                else 									
                                    hist.speedTicks = math.max(0, (hist.speedTicks or 0) - 2) 								
                                end 							
                            else 								
                                hist.speedTicks = 0 							
                            end 						end 						
                        hist.warmupFrames = math.min(wf + 1, MIN_WARMUP_FRAMES + 1) 					
                    end 					
                    playerHistory[p] = { 						
                        lastPosition = pos, 						
                        lastCFrame = hrp.CFrame, 						
                        aimTicks = hist and hist.aimTicks or 0, 						
                        speedTicks = hist and hist.speedTicks or 0, 						
                        warmupFrames = hist and math.min((hist.warmupFrames or 0) + 1, MIN_WARMUP_FRAMES + 1) or 0, 					
                    } 				
                end 			
            end 		
        end 	
    end 	
    local char = localPlayer.Character; if not char then return end 	
    local hum = char:FindFirstChildOfClass("Humanoid") 	
    if hum and hum.WalkSpeed ~= customWalkSpeed then hum.WalkSpeed = customWalkSpeed end 	
    if not antiFlingEnabled then return end 	
    local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end 	
    local v = hrp.AssemblyLinearVelocity 	
    local av = hrp.AssemblyAngularVelocity 	
    local falling = hum and (hum:GetState() == Enum.HumanoidStateType.Jumping or hum:GetState() == Enum.HumanoidStateType.Freefall) 	
    if falling then 		
        if math.abs(v.X) > 35 or math.abs(v.Z) > 35 then 			
            hrp.AssemblyLinearVelocity = Vector3.new(0, v.Y, 0) 		
        end 	
    else 		
        if v.Magnitude > 35 or math.abs(v.Y) > 40 then 			
            hrp.AssemblyLinearVelocity = Vector3.new(0, math.clamp(v.Y,-20,20), 0) 		
        end 	
    end 	
    if av.Magnitude > 5 then hrp.AssemblyAngularVelocity = Vector3.zero end 	
    for _, part in ipairs(char:GetChildren()) do 		
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then part.CanCollide = false end 	
    end 
end) 

