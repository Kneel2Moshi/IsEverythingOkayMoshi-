local function getPlayerRole(targetPlayer)
	local character = targetPlayer.Character
	local backpack = targetPlayer:FindFirstChild("Backpack")
	
	local hasKnife = (character and character:FindFirstChild("Knife")) or 
	                 (backpack and backpack:FindFirstChild("Knife"))
	                 
	local hasGun = (character and character:FindFirstChild("Gun")) or 
	               (backpack and backpack:FindFirstChild("Gun")) or
	               (character and character:FindFirstChild("Revolver")) or
	               (backpack and backpack:FindFirstChild("Revolver"))

	if hasKnife then
		return "Murderer", Color3.fromRGB(221, 29, 29)
	elseif hasGun then
		return "Sheriff", Color3.fromRGB(22, 120, 240)
	end
	
	return "Innocent", Color3.fromRGB(62, 197, 32)
end

local function getMurderer()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer then
			local role, _ = getPlayerRole(p)
			if role == "Murderer" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				return p
			end
		end
	end
	return nil
end

local function applyEspTags(targetPlayer)
	if targetPlayer == localPlayer then return end
	
	local function onCharAdded(character)
		-- Give the game engine a brief moment to finish generating/teleporting the character
		task.wait(0.5)
		
		local head = character:WaitForChild("Head", 5)
		if not head then return end
		
		if activeEsp[targetPlayer] then pcall(function() activeEsp[targetPlayer]:Destroy() end) end
		if activeOutlines[targetPlayer] then pcall(function() activeOutlines[targetPlayer]:Destroy() end) end
		
		local roleName, roleColor = getPlayerRole(targetPlayer)
		
		-- 1. Billboard Text Tag
		local bGui = Instance.new("BillboardGui")
		bGui.Name = targetPlayer.Name .. "_TagESP"
		bGui.Size = UDim2.new(0, 150, 0, 30)
		bGui.StudsOffset = Vector3.new(0, 3.2, 0) 
		bGui.AlwaysOnTop = true
		
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 1, 0)
		label.BackgroundTransparency = 1
		label.Font = Enum.Font.Code
		label.TextSize = 11
		label.TextStrokeTransparency = 0.5
		label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		
		label.Text = string.format("%s\n[%s]", targetPlayer.Name:upper(), roleName)
		label.TextColor3 = roleColor
		label.Visible = espEnabled
		
		label.Parent = bGui
		bGui.Parent = head
		activeEsp[targetPlayer] = bGui
		
		-- 2. Outline Highlight (Housed in safe workspace storage)
		local highlight = Instance.new("Highlight")
		highlight.Name = targetPlayer.Name .. "_Outline"
		highlight.FillTransparency = 1
		highlight.OutlineTransparency = 0
		highlight.OutlineColor = roleColor
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Enabled = espEnabled
		
		highlight.Adornee = character -- Explicitly targets the body model safely
		highlight.Parent = OutlineStorage
		activeOutlines[targetPlayer] = highlight
		
		local connection
		connection = RunService.RenderStepped:Connect(function()
			if not character or not character.Parent or not bGui or not bGui.Parent or not highlight or not highlight.Parent then
				if connection then connection:Disconnect() end
				return
			end
			if espEnabled then
				local currentRole, currentColor = getPlayerRole(targetPlayer)
				label.Text = string.format("%s\n[%s]", targetPlayer.Name:upper(), currentRole)
				label.TextColor3 = currentColor
				
				highlight.Adornee = character
				highlight.OutlineColor = currentColor
			end
		end)
	end
	
	if targetPlayer.Character then task.spawn(onCharAdded, targetPlayer.Character) end
	targetPlayer.CharacterAdded:Connect(onCharAdded)
end

local function isHeldByPlayer(object)
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character and object:IsDescendantOf(player.Character) then
			return true
		end
	end
	return false
end

local function findDroppedGun()
	for _, object in ipairs(Workspace:GetDescendants()) do
		if object:IsA("Part") or object:IsA("MeshPart") then
			if (object.Name == "GunDrop" or object.Name == "DroppedGun") and not isHeldByPlayer(object) then
				return object
			elseif object.Name == "Handle" and object.Parent:IsA("Tool") and (object.Parent.Name == "Gun" or object.Parent.Name == "Revolver") then
				if not isHeldByPlayer(object) then
					return object
				end
			end
		end
	end
	return nil
end

local function updateDroppedGunEsp()
	local gunTarget = findDroppedGun()
	if gunTarget and gunEspEnabled then
		if not droppedGunEspInstance or droppedGunEspInstance.Parent ~= gunTarget then
			if droppedGunEspInstance then droppedGunEspInstance:Destroy() end
			
			droppedGunEspInstance = Instance.new("BillboardGui")
			droppedGunEspInstance.Name = "DroppedGunESP"
			droppedGunEspInstance.Size = UDim2.new(0, 120, 0, 25)
			droppedGunEspInstance.StudsOffset = Vector3.new(0, 2, 0)
			droppedGunEspInstance.AlwaysOnTop = true
			
			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, 0, 1, 0)
			label.BackgroundTransparency = 1
			label.Font = Enum.Font.Code
			label.TextSize = 11
			label.TextColor3 = Color3.fromRGB(255, 235, 40)
			label.TextStrokeTransparency = 0.5
			label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
			label.Text = "* DROPPED GUN *"
			
			label.Parent = droppedGunEspInstance
			droppedGunEspInstance.Parent = gunTarget
		end
	else
		if droppedGunEspInstance then
			droppedGunEspInstance:Destroy()
			droppedGunEspInstance = nil
		end
	end
end

local function findPartialPlayer(searchStr)
	searchStr = searchStr:lower()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer and (p.Name:lower():sub(1, #searchStr) == searchStr or p.DisplayName:lower():sub(1, #searchStr) == searchStr) then
			return p
		end
	end
	return nil
end

local function safeTeleport(targetCFrame)
	local char = localPlayer.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	
	if hrp then
		hrp.AssemblyLinearVelocity = Vector3.zero
		hrp.AssemblyAngularVelocity = Vector3.zero
	end
	
	char:PivotTo(targetCFrame)
	
	if humanoid then
		humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	end
end

RunService.RenderStepped:Connect(function()
	if spectateEnabled and selectedPlayerName ~= "" then
		local targetPlayer = Players:FindFirstChild(selectedPlayerName)
		local targetChar = targetPlayer and targetPlayer.Character
		local targetHumanoid = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
		
		if targetHumanoid then
			camera.CameraSubject = targetHumanoid
			return
		end
	end

	if camLockEnabled then
		local murderer = getMurderer()
		local mudHrp = murderer and murderer.Character and murderer.Character:FindFirstChild("HumanoidRootPart")
		
		if mudHrp then
			local targetLookCFrame = CFrame.lookAt(camera.CFrame.Position, mudHrp.Position)
			local alphaFactor = math.clamp(1 / (smoothnessLevel * 2), 0.01, 1)
			camera.CFrame = camera.CFrame:Lerp(targetLookCFrame, alphaFactor)
		end
	end
end)

RunService.Heartbeat:Connect(function()
	updateDroppedGunEsp()
	
	local character = localPlayer.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.WalkSpeed ~= customWalkSpeed then
		humanoid.WalkSpeed = customWalkSpeed
	end

	if not antiFlingEnabled then return end
	local hrp = character and character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	if hrp.AssemblyLinearVelocity.Magnitude > 45 then
		hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
	end
	if hrp.AssemblyAngularVelocity.Magnitude > 25 then
		hrp.AssemblyAngularVelocity = Vector3.zero
	end
end)

