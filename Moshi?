FlingButton.MouseButton1Click:Connect(function()
	if antiFlingEnabled then FlingButton.Text = "DISABLE ANTI-FLING FIRST" return end
	local targetPlayer = findPartialPlayer(FlingInput.Text)
	if not targetPlayer or not targetPlayer.Character then FlingButton.Text = "PLAYER NOT FOUND" return end

	local myChar = localPlayer.Character
	local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
	local targetHrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")

	if myHrp and targetHrp then
		FlingButton.Text = "FLINGING..."
		local originalPos = myHrp.CFrame
		local duration = 0.65 
		local start = os.clock()
		
		local flingConnection
		flingConnection = RunService.Heartbeat:Connect(function()
			pcall(function()
				if os.clock() - start > duration or not myHrp or not targetHrp then
					flingConnection:Disconnect()
					myHrp.AssemblyLinearVelocity = Vector3.zero
					myHrp.AssemblyAngularVelocity = Vector3.zero
					myChar:PivotTo(originalPos)
					FlingButton.Text = "EXECUTE FLING"
					return
				end
				
				for _, part in ipairs(myChar:GetChildren()) do
					if part:IsA("BasePart") then part.CanCollide = false end
				end
				
				local syncTime = os.clock() * 75
				local positionalOffset = Vector3.new(math.sin(syncTime) * 0.15, 0, math.cos(syncTime) * 0.15)
				myChar:PivotTo(CFrame.new(targetHrp.Position + positionalOffset))
				
				myHrp.AssemblyAngularVelocity = Vector3.new(0, 30000, 0)
				myHrp.AssemblyLinearVelocity = Vector3.new(30000, 30000, 30000)
			end)
		end)
	end
end)

