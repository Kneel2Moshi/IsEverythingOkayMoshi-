createActionButton("TELEPORT TO LOBBY", 11.1, function(btn)
	local lobbyTarget = Workspace:FindFirstChild("RegularLobby") or Workspace:FindFirstChild("Lobby") or Workspace:FindFirstChild("LobbySpawn")
	if not lobbyTarget then
		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("SpawnLocation") and (obj.Name:lower():find("lobby") or obj.Name == "SpawnLocation") then
				lobbyTarget = obj
				break
			end
		end
	end
	
	if lobbyTarget then
		local landingCFrame
		if lobbyTarget:IsA("Model") then
			local primary = lobbyTarget.PrimaryPart or lobbyTarget:FindFirstChildWhichIsA("BasePart", true)
			if primary then landingCFrame = primary.CFrame * CFrame.new(0, 4, 0) end
		else
			landingCFrame = lobbyTarget.CFrame * CFrame.new(0, 4, 0)
		end
		
		if landingCFrame then
			safeTeleport(landingCFrame)
			btn.Text = "TP'D TO LOBBY!"
			task.delay(1.5, function() btn.Text = "TELEPORT TO LOBBY" end)
		else
			btn.Text = "COULD NOT POSITION LOBBY"
			task.delay(1.5, function() btn.Text = "TELEPORT TO LOBBY" end)
		end
	else
		btn.Text = "LOBBY SPAWN NOT FOUND"
		task.delay(1.5, function() btn.Text = "TELEPORT TO LOBBY" end)
	end
end)

createActionButton("TELEPORT TO ACTIVE MAP", 11.2, function(btn)
	local mapContainer = Workspace:FindFirstChild("Normal") or Workspace:FindFirstChild("Map") or Workspace:FindFirstChild("Maps")
	local activeMap = nil
	
	if mapContainer then
		for _, child in ipairs(mapContainer:GetChildren()) do
			if child:IsA("Model") and child.Name ~= "RegularLobby" and child.Name ~= "Lobby" then
				activeMap = child
				break
			end
		end
	end
	
	if not activeMap then
		for _, obj in ipairs(Workspace:GetChildren()) do
			if obj:IsA("Model") and obj.Name ~= "Lobby" and obj.Name ~= "The Lobby" and obj.Name ~= "RegularLobby" and not Players:GetPlayerFromCharacter(obj) then
				if obj:FindFirstChild("Spawns") or obj:FindFirstChild("CoinContainer") or obj:FindFirstChild("Geometry") then
					activeMap = obj
					break
				end
			end
		end
	end
	
	if activeMap then
		local spawnLocation = activeMap:FindFirstChild("Spawns", true) or activeMap:FindFirstChild("Spawn", true)
		local targetPart = spawnLocation and spawnLocation:FindFirstChildWhichIsA("BasePart", true) or activeMap:FindFirstChildWhichIsA("BasePart", true)
		
