createActionButton("TELEPORT TO GUN", 11, function(btn)
	local gunPart = findDroppedGun()
	if not gunPart then
		btn.Text = "THE GUN IS NOT DROPPED"
		btn.TextColor3 = Color3.fromRGB(221, 29, 29)
		task.delay(2, function() btn.Text = "TELEPORT TO GUN" btn.TextColor3 = Color3.fromRGB(255, 255, 255) end)
