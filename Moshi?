local function markAsExploiter(p, reason) 	
    if not flaggedExploiters[p] then 		
        flaggedExploiters[p] = reason 		
        warn("[MOSHI] " .. p.Name .. " flagged: " .. reason) 
        if appendLog then
            appendLog(string.format("[%s] Flagged for %s", p.Name:upper(), reason))
        end
    end 
end 

local function clearHistory(p) 	
    playerHistory[p] = nil 
