    local state = false 	
    btn.MouseButton1Click:Connect(function() 		
        state = not state 		
        lbl.TextColor3 = state and C_ORANGE or C_WHITE 
        sk.Color = state and C_STROKE or Color3.fromRGB(120,80,45) 		
        lbl.Text = labelText .. (state and " [ON]" or " [OFF]") 		
        if state then 			
            TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundColor3 = C_ORANGE}):Play() 		
        else 			
            TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundColor3 = C_WHITE}):Play() 		
        end 		
        appendLog(labelText .. (state and " activated." or " deactivated.")) 
        
        -- Custom clean implementation pass to forcefully reset switch back on rejection
        cb(state, function()
            state = false
            lbl.TextColor3 = C_WHITE
            sk.Color = Color3.fromRGB(120,80,45)
            lbl.Text = labelText .. " [OFF]"
            TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundColor3 = C_WHITE}):Play()
        end) 	
    end) 	
    return btn, sk 
end 

