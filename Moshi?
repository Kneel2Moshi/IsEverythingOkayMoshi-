local function animateMenuToggle(targetState)
	if uiTweenInProgress then return end
	uiTweenInProgress = true
	
	if targetState == true then
		MainFrame.Size = UDim2.new(0, 230, 0, 0)
		MainFrame.Visible = true
		local openTween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 230, 0, 210)})
		openTween:Play()
		openTween.Completed:Wait()
		menuOpenState = true
	else
		local closeTween = TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 230, 0, 0)})
		closeTween:Play()
		closeTween.Completed:Wait()
		MainFrame.Visible = false
		menuOpenState = false
	end
	uiTweenInProgress = false
end

