local function createToggle(labelText, layoutOrder, callback)
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, 0, 0, 30)
	button.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	button.Text = labelText .. " [OFF]"
	button.Font = Enum.Font.Code
	button.TextSize = 10
	button.TextColor3 = Color3.fromRGB(180, 180, 180)
	button.LayoutOrder = layoutOrder
	button.Parent = Container

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(50, 50, 50)
	stroke.Thickness = 1
	stroke.Parent = button

	local state = false
	button.MouseButton1Click:Connect(function()
		state = not state
		button.TextColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 180)
		stroke.Color = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(50, 50, 50)
		button.Text = labelText .. (state and " [ON]" or " [OFF]")
		callback(state)
	end)
	return button, stroke
end

